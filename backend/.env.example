# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# CORS — comma-separated allowlist of origins.
# Must include BOTH the external professional website (which POSTs the
# contact form to /api/contact) AND this dashboard SPA (which GETs the
# list and detail endpoints). Example:
#   CORS_ORIGIN=https://your-portfolio.example.com,https://dashboard.example.com
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Symmetric secret used to sign session JWTs. REQUIRED in production unless
# AUTH_JWT_KEYS is set (see below).
# Generate with: openssl rand -hex 48
# Minimum 32 chars enforced at boot. With this single-key config the JWTs
# carry a `kid` of "default" — fine until you need to rotate, then move to
# AUTH_JWT_KEYS.
AUTH_JWT_SECRET=

# Multi-key JWT signing — opt in when you need rotation without forcing
# everyone to log in again.
#
# Shape: a JSON array of `{kid, secret, active}` entries; the active key
# signs new tokens, the inactive ones keep verifying already-issued ones
# until they expire (max = AUTH_ACCESS_TTL_SECONDS).
#
# Rotation procedure:
#   1. Add a new entry alongside the old one, mark `active: true` on the new
#      one and `active: false` on the old one. Restart the API.
#   2. Wait >= AUTH_ACCESS_TTL_SECONDS so every JWT minted under the old
#      key has expired.
#   3. Remove the old entry and restart again.
#
# When AUTH_JWT_KEYS is set, AUTH_JWT_SECRET is ignored.
#
# Example (keep the value on a single line in the .env file):
#   AUTH_JWT_KEYS=[{"kid":"k1","secret":"<hex-48>","active":true},{"kid":"k0","secret":"<old-hex-48>","active":false}]
AUTH_JWT_KEYS=

# Access-token lifetime (seconds). Default 15 minutes. The refresh-token
# rotation flow keeps the session alive without the user re-entering creds.
AUTH_ACCESS_TTL_SECONDS=900

# Refresh-token lifetime (seconds). Default 7 days. The browser will be
# silently re-issued a new pair on /api/auth/refresh as long as the user
# is active within this window.
AUTH_REFRESH_TTL_SECONDS=604800

# Cookie names (rename if you run multiple apps under the same host and want
# to keep their sessions independent).
AUTH_COOKIE_NAME=rf_session
AUTH_REFRESH_COOKIE_NAME=rf_refresh
AUTH_CSRF_COOKIE_NAME=rf_csrf

# Cookie attributes. In production these default to Strict + Secure.
# In dev set AUTH_COOKIE_SECURE=false so localhost (HTTP) browsers accept it.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# Argon2id parameters (memCost is in KiB). Defaults match the OWASP cheat
# sheet baseline (19 MiB / t=2 / p=1). Bump on bigger nodes.
AUTH_ARGON_MEM_KIB=19456
AUTH_ARGON_TIME_COST=2
AUTH_ARGON_PARALLELISM=1

# Password reset token TTL (seconds). Default 1 hour. Tokens are single-use.
AUTH_PASSWORD_RESET_TTL_SECONDS=3600

# URL the password-reset email points users at. The token is appended as
# ?token=<hex>. In dev we just log the link to stdout; in production wire the
# `sendPasswordResetEmail` helper in authController.ts to your email provider.
AUTH_PASSWORD_RESET_URL=http://localhost:5173/reset-password

# How often the housekeeping job sweeps expired refresh + reset tokens.
# Default 1h (3600000 ms).
REFRESH_TOKEN_PURGE_INTERVAL_MS=3600000

# -----------------------------------------------------------------------------
# First-admin bootstrap (optional)
# -----------------------------------------------------------------------------
# When both are set AND the users table is empty, the server creates a single
# admin user on startup with these credentials. Subsequent restarts are no-ops.
# Use this to seed dev environments or do the very first prod deploy, then
# UNSET these and rotate the password from the dashboard.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
# Required to actually run the bootstrap in NODE_ENV=production. Default off.
ADMIN_BOOTSTRAP_ALLOW_PROD=false

# -----------------------------------------------------------------------------
# Service-to-service (optional)
# -----------------------------------------------------------------------------
# If set, server-to-server callers can authenticate to admin GET endpoints
# with: Authorization: Bearer <ADMIN_STATIC_TOKEN>. Off by default — leave
# empty in any deploy that doesn't run an automation that needs it.
# Generate with: openssl rand -hex 32
ADMIN_STATIC_TOKEN=

# Optional: HMAC shared secret for the public POST.
# When set, requests must include  X-Signature: sha256=<hex hmac of body>
# Leave empty to skip the check (opt-in hardening).
INGEST_HMAC_SECRET=

# PostgreSQL database connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=receive_forms
DB_POOL_MAX=10

# TypeORM behaviour
# Migrations are authoritative for schema in this project. Keep synchronize=false
# in EVERY environment (dev included). Flipping to true runs `ALTER`/`DROP` based
# on entity metadata diffs and can silently destroy data in production.
DB_SYNCHRONIZE=false
DB_LOGGING=false
