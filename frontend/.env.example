# Base URL the dashboard uses to call the admin API
# (GET /api/contact, GET /api/contact/:id, /api/auth/*).
# Leave empty to use a relative path (recommended when served behind the
# same domain as the API via Traefik). Set it for cross-origin local
# development or when the dashboard is hosted on a different domain than
# the API.
VITE_API_BASE_URL=
